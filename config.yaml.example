# QWS Configuration Example

keybindings:
  modifier: Alt
  key: Tab
  backward: Shift
  workspace_modifier: Ctrl
  cancel: Escape

appearance:
  thumbnail:
    width: 256
    height: 256
  spacing: 300
  perspective: 0.6
  shadow:
    offset: 10
    blur: 15
  font:
    # Font paths in order: primary first, then fallbacks
    # Multiple fonts enable glyph-level fallback for missing characters
    paths:
      - "/usr/share/fonts/truetype/noto/NotoSans-Regular.ttf"
      - "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"
    size: 14
  colors:
    theme: auto  # auto (follow system), dark, light
    dark:
      background: "#1a1a2e"
      selection_frame: "#4a9eff"
      text: "#ffffff"
      shadow: "rgba(0, 0, 0, 0.8)"
      inactive_frame: "#404050"
      urgent_title_background: "#d32f2f"
    light:
      background: "#f5f5f5"
      selection_frame: "#0078d4"
      text: "#1a1a1a"
      shadow: "rgba(0, 0, 0, 0.3)"
      inactive_frame: "#cccccc"
      urgent_title_background: "#e53935"
  window_background:
    enabled: true       # Enable semi-transparent background for entire selector window
    opacity: 0.85       # Background opacity (0.0-1.0, where 1.0 is fully opaque)
    border_radius: 20   # Corner radius in pixels for rounded edges
  window_padding:
    horizontal: 20px    # Horizontal padding from screen edges (e.g., "5%" or "50px")
    vertical: 20px      # Vertical padding from screen edges (e.g., "5%" or "50px")

behavior:
  snapshot_interval: 10s
  show_delay: 0ms

windows:
  workspace: current  # current, all, all-except-current
  ignore_skip_taskbar: false
  sort_minimized_last: false

log:
  level: info  # trace, debug, info, warn, error
  format: console  # console, json
